# Local host execution:
# Docker Compose overrides DATABASE_URL to use the db service internally.
# Render production:
# Use the PostgreSQL Internal Database URL from Render or deploy with render.yaml.
# Do not use localhost, 127.0.0.1 or the Docker Compose host "db" in production.
APP_NAME=Energy Bill AI Backend
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://energy_user:energy_pass@localhost:5432/energy_bill_ai
UPLOADS_DIR=uploads
LOG_LEVEL=INFO
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
MAX_UPLOAD_SIZE_MB=15
LOW_CONFIDENCE_THRESHOLD=0.75
OCR_LANGUAGES=por+eng
# Example on Windows:
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
TESSERACT_CMD=
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_REQUESTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
UPLOAD_RATE_LIMIT_REQUESTS=10
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=300
EXTRACTION_RATE_LIMIT_REQUESTS=10
EXTRACTION_RATE_LIMIT_WINDOW_SECONDS=300
FORECAST_HORIZON_MONTHS=8
PROPHET_MIN_HISTORY_POINTS=12
FORECAST_INTERVAL_ZSCORE=1.96
ENABLE_PROPHET=true
